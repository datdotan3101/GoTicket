{
  "name": "goticket-server",
  "version": "1.0.0",
  "description": "GoTicket backend API (free-tier friendly)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:admin": "node database/seeds/seed_admin.js",
    "seed:sports": "node database/seeds/seed_sports.js",
    "seed:demo": "node database/seeds/seed_demo_match.js",
    "db:create": "node database/create-db.js",
    "db:migrate": "node database/migrate-db.js",
    "seed": "npm run db:create && npm run db:migrate && npm run seed:admin && npm run seed:sports && npm run seed:demo",
    "lint": "node -e \"console.log('No linter configured yet')\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.0",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^18.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "vitest": "^2.1.9"
  }
}
